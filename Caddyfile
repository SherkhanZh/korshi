# Caddy auto-provisions and renews HTTPS (Let's Encrypt) for $DOMAIN.
# Set DOMAIN=your.domain in the .env next to docker-compose.https.yml, and point
# that domain's DNS A record (and www) at this server. Caddy listens on 80 (ACME
# + redirect) and 443 (TLS), proxying to the nginx `web` container which serves
# the panel and reverse-proxies /api → the backend.
{$DOMAIN} {
	encode gzip
	reverse_proxy web:80
}

# Redirect www → the canonical root domain (remove this block if you have no
# www DNS record, otherwise Caddy will keep trying to get a cert for it).
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
